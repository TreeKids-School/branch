rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reports: authenticated users can read/write
    match /reports/{date} {
      allow read, write: if request.auth != null;
    }
    // Meta (children master list): authenticated users can read/write
    match /meta/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
