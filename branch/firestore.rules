rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------------------------------------
    // Children Master Collection
    // ------------------------------------------------------------------------
    match /children/{childId} {
      allow read: if request.auth != null;
      
      // Create: Required Fields & Ownership
      allow create: if request.auth != null &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.createdBy == request.auth.uid;
        
      // Update: Shared staff access (Authenticated only)
      allow update: if request.auth != null &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0;
        
      // Delete: Restricted to original creator
      allow delete: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;

      // Existing sub-collections (Explicit paths)
      match /app_categories/{category}/tree_communications/{date} {
        allow read, create, update: if request.auth != null;
        // Keep delete restricted to creator if data has ownership, else restricted for now
        allow delete: if request.auth != null && 
          (resource.data.authorId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      }
    }

    // ------------------------------------------------------------------------
    // Other Collections (Reports, Meta, Staffs)
    // ------------------------------------------------------------------------
    match /reports/{date} {
      allow read, create, update: if request.auth != null;
      allow delete: if false; 
    }
    
    match /meta/{doc} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
    
    match /staffs/{staffId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }
  }
}
