{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/storage",
        "function": "storageApi"
      },
      {
        "source": "/api/pii",
        "function": "piiApi"
      },
      {
        "source": "/api/gemini",
        "function": "callGemini"
      }
    ]
  }
}